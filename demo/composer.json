{
    "name": "oddsockets/php-demo",
    "description": "Runnable pub/sub round-trip demo for the OddSockets PHP SDK",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "jyswee/oddsockets-php-sdk": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "beta",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
