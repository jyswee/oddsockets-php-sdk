{
    "name": "jyswee/oddsockets-php-sdk",
    "description": "Official PHP SDK for OddSockets real-time messaging platform",
    "type": "library",
    "keywords": ["websockets", "realtime", "messaging", "php", "oddsockets"],
    "homepage": "https://oddsockets.com",
    "license": "MIT",
    "authors": [
        {
            "name": "OddSockets Team",
            "email": "support@oddsockets.com",
            "homepage": "https://oddsockets.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-curl": "*",
        "guzzlehttp/guzzle": "^7.8",
        "ratchet/pawl": "^0.4",
        "react/socket": "^1.15",
        "react/http": "^1.9",
        "react/stream": "^1.3",
        "react/promise": "^3.0",
        "evenement/evenement": "^3.0",
        "monolog/monolog": "^3.4",
        "symfony/serializer": "^6.3",
        "symfony/property-access": "^6.3",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.4",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "friendsofphp/php-cs-fixer": "^3.34",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "OddSockets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OddSockets\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse src --level=8",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "quality": [
            "@phpstan",
            "@cs-check",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "version": "0.1.0-beta.1"
}
